# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# APPWRITE_ENDPOINT: Paste your real Appwrite Endpoint (default: https://sgp.cloud.appwrite.io/v1) inside the Secrets panel.
APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1

# APPWRITE_PROJECT_ID: Paste your real Appwrite Project ID inside the Secrets panel.
APPWRITE_PROJECT_ID=6a1ee8cb001248095722

# Spotify API Client Credentials
SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID
SPOTIFY_CLIENT_SECRET=YOUR_SPOTIFY_CLIENT_SECRET

# GIPHY API Key for search and trending gifs (use public beta key or custom key)
GIPHY_API_KEY=YOUR_GIPHY_API_KEY

# YouTube Data API v3 Key for YouTube Music searches
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY

