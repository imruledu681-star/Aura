# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# APPWRITE_ENDPOINT: Paste your real Appwrite Endpoint (default: https://sgp.cloud.appwrite.io/v1) inside the Secrets panel.
APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1

# APPWRITE_PROJECT_ID: Paste your real Appwrite Project ID inside the Secrets panel.
APPWRITE_PROJECT_ID=6a1ee8cb001248095722
